modules = ["nodejs-20", "ruby-3.2", "swift-5.8"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Expo Web"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Serve Production"

[[workflows.workflow]]
name = "Expo Web"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run web"
waitForPort = 8081

[[workflows.workflow]]
name = "Serve Production"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx serve dist -l 5000 --single"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8082
externalPort = 3001

[deployment]
deploymentTarget = "autoscale"
build = ["npm", "run", "build:web"]
publicDir = "dist"
run = ["npx", "serve", "dist", "-l", "5000"]
